FROM booking-portal-tests:latest AS deps

FROM maven:3.9-eclipse-temurin-21

WORKDIR /build

# Reuse cached Maven repository from previous build
COPY --from=deps /root/.m2 /root/.m2
COPY pom.xml .

# Copy production source
COPY src ./src

# Copy test sources from approved root-level directories
COPY unit_tests ./unit_tests
COPY api_tests  ./api_tests

ENTRYPOINT ["mvn"]
CMD ["verify", "-B"]
