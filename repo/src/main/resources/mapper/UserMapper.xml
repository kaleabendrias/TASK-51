<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.booking.mapper.UserMapper">

    <resultMap id="userResult" type="User">
        <id property="id" column="id"/>
        <result property="username" column="username"/>
        <result property="email" column="email"/>
        <result property="passwordHash" column="password_hash"/>
        <result property="fullName" column="full_name"/>
        <result property="phone" column="phone"/>
        <result property="roleId" column="role_id"/>
        <result property="enabled" column="enabled"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
        <result property="pointsBalance" column="points_balance"/>
        <result property="roleName" column="role_name"/>
    </resultMap>

    <sql id="selectUser">
        SELECT u.*, r.name AS role_name
        FROM users u
        JOIN roles r ON u.role_id = r.id
    </sql>

    <select id="findById" resultMap="userResult">
        <include refid="selectUser"/>
        WHERE u.id = #{id}
    </select>

    <select id="findByUsername" resultMap="userResult">
        <include refid="selectUser"/>
        WHERE u.username = #{username}
    </select>

    <select id="findByEmail" resultMap="userResult">
        <include refid="selectUser"/>
        WHERE u.email = #{email}
    </select>

    <select id="findAll" resultMap="userResult">
        <include refid="selectUser"/>
        ORDER BY u.created_at DESC
    </select>

    <select id="findByRoleId" resultMap="userResult">
        <include refid="selectUser"/>
        WHERE u.role_id = #{roleId}
        ORDER BY u.full_name
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO users (username, email, password_hash, full_name, phone, role_id, enabled)
        VALUES (#{username}, #{email}, #{passwordHash}, #{fullName}, #{phone}, #{roleId}, #{enabled})
    </insert>

    <update id="update">
        UPDATE users
        SET email = #{email}, full_name = #{fullName}, phone = #{phone},
            role_id = #{roleId}, enabled = #{enabled},
            password_hash = #{passwordHash}
        WHERE id = #{id}
    </update>

    <update id="updateProfile">
        UPDATE users
        SET email = #{email}, full_name = #{fullName}, role_id = #{roleId}, enabled = #{enabled}
        WHERE id = #{id}
    </update>

    <update id="updatePasswordHash">
        UPDATE users SET password_hash = #{passwordHash} WHERE id = #{id}
    </update>

    <update id="updateEnabled">
        UPDATE users SET enabled = #{enabled} WHERE id = #{id}
    </update>

    <update id="updatePhone">
        UPDATE users SET phone = #{phone} WHERE id = #{id}
    </update>

    <select id="findByDepartment" resultMap="userResult">
        <include refid="selectUser"/> WHERE u.department = #{department}
    </select>

    <select id="findByTeam" resultMap="userResult">
        <include refid="selectUser"/> WHERE u.team = #{team}
    </select>
</mapper>
